# Normaliza los finales de línea: Git guarda LF en el repo y convierte
# automáticamente según la plataforma al hacer checkout.
* text=auto

# Archivos que deben usar siempre LF (scripts y configuración multiplataforma)
*.sh   text eol=lf
*.py   text eol=lf
*.md   text eol=lf
*.json text eol=lf
*.yml  text eol=lf
*.yaml text eol=lf

# Archivos específicos de Windows: siempre CRLF
*.ps1  text eol=crlf
*.psm1 text eol=crlf
*.bat  text eol=crlf
*.cmd  text eol=crlf

# Binarios: sin conversión
*.png  binary
*.jpg  binary
*.gif  binary
*.ico  binary
*.pdf  binary
*.zip  binary
